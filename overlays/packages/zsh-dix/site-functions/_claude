#compdef claude

# Zsh completion for Claude Code CLI, synced against local Claude Code 2.1.126.

local curcontext="$curcontext" state line
typeset -A opt_args

local -a commands
commands=(
  'agents:List and manage configured agents'
  'auth:Manage authentication'
  'auto-mode:Inspect auto mode classifier configuration'
  'doctor:Check the health of the Claude Code auto-updater'
  'install:Install Claude Code native build'
  'mcp:Configure and manage MCP servers'
  'plugin:Manage Claude Code plugins'
  'plugins:Manage Claude Code plugins'
  'project:Manage Claude Code project state'
  'remote-control:Start Remote Control server mode'
  'setup-token:Set up a long-lived authentication token'
  'ultrareview:Run a cloud-hosted multi-agent code review'
  'update:Check for updates and install if available'
  'upgrade:Check for updates and install if available'
)

local -a auth_commands
auth_commands=(
  'help:Display help for command'
  'login:Sign in to your Anthropic account'
  'logout:Log out from your Anthropic account'
  'status:Show authentication status'
)

local -a auto_mode_commands
auto_mode_commands=(
  'config:Print the effective auto mode config as JSON'
  'critique:Get AI feedback on custom auto mode rules'
  'defaults:Print the default auto mode rules as JSON'
  'help:Display help for command'
)

local -a mcp_commands
mcp_commands=(
  'add:Add an MCP server to Claude Code'
  'add-from-claude-desktop:Import MCP servers from Claude Desktop'
  'add-json:Add an MCP server with a JSON string'
  'get:Get details about an MCP server'
  'help:Display help for command'
  'list:List configured MCP servers'
  'remove:Remove an MCP server'
  'reset-project-choices:Reset all approved and rejected project-scoped servers'
  'serve:Start the Claude Code MCP server'
)

local -a plugin_commands
plugin_commands=(
  'disable:Disable an enabled plugin'
  'enable:Enable a disabled plugin'
  'help:Display help for command'
  'install:Install a plugin from available marketplaces'
  'i:Install a plugin from available marketplaces'
  'list:List installed plugins'
  'marketplace:Manage Claude Code marketplaces'
  'prune:Remove auto-installed dependencies that are no longer needed'
  'autoremove:Remove auto-installed dependencies that are no longer needed'
  'tag:Create a plugin release tag'
  'uninstall:Uninstall an installed plugin'
  'remove:Uninstall an installed plugin'
  'update:Update a plugin to the latest version'
  'validate:Validate a plugin or marketplace manifest'
)

local -a marketplace_commands
marketplace_commands=(
  'add:Add a marketplace from a URL, path, or GitHub repo'
  'help:Display help for command'
  'list:List all configured marketplaces'
  'remove:Remove a configured marketplace'
  'rm:Remove a configured marketplace'
  'update:Update marketplace(s) from their source'
)

local -a project_commands
project_commands=(
  'help:Display help for command'
  'purge:Delete all Claude Code state for a project'
)

case $words[2] in
  auth)
    if (( CURRENT == 3 )); then
      _describe 'auth command' auth_commands
      return
    fi
    case $words[3] in
      login)
        _arguments \
          '--claudeai[Use Claude subscription]' \
          '--console[Use Anthropic Console for API usage billing]' \
          '--email[Pre-populate email address]:email:' \
          '--sso[Force SSO login flow]' \
          '(-h --help)'{-h,--help}'[Display help]'
        ;;
      status)
        _arguments \
          '--json[Output as JSON]' \
          '--text[Output as human-readable text]' \
          '(-h --help)'{-h,--help}'[Display help]'
        ;;
      logout|help)
        _arguments '(-h --help)'{-h,--help}'[Display help]'
        ;;
      *)
        _message 'no more arguments'
        ;;
    esac
    return
    ;;
  auto-mode)
    if (( CURRENT == 3 )); then
      _describe 'auto mode command' auto_mode_commands
      return
    fi
    case $words[3] in
      critique)
        _arguments \
          '--model[Override which model is used]:model:' \
          '(-h --help)'{-h,--help}'[Display help]'
        ;;
      config|defaults|help)
        _arguments '(-h --help)'{-h,--help}'[Display help]'
        ;;
      *)
        _message 'no more arguments'
        ;;
    esac
    return
    ;;
  mcp)
    if (( CURRENT == 3 )); then
      _describe 'mcp command' mcp_commands
      return
    fi
    case $words[3] in
      serve)
        _arguments \
          '(-d --debug)'{-d,--debug}'[Enable debug mode]' \
          '--verbose[Override verbose mode setting from config]' \
          '(-h --help)'{-h,--help}'[Display help]'
        ;;
      add)
        _arguments \
          '(-s --scope)'{-s,--scope}'[Configuration scope]:scope:(local user project)' \
          '(-t --transport)'{-t,--transport}'[Transport type]:transport:(stdio sse http)' \
          '*'{-e,--env}'[Set environment variables]:env:' \
          '*'{-H,--header}'[Set HTTP or WebSocket headers]:header:' \
          '(-h --help)'{-h,--help}'[Display help]' \
          ':name:' \
          ':command or url:_files' \
          '*:args:_files'
        ;;
      remove)
        _arguments \
          '(-s --scope)'{-s,--scope}'[Configuration scope]:scope:(local user project)' \
          '(-h --help)'{-h,--help}'[Display help]' \
          ':name:'
        ;;
      add-json)
        _arguments \
          '(-s --scope)'{-s,--scope}'[Configuration scope]:scope:(local user project)' \
          '(-h --help)'{-h,--help}'[Display help]' \
          ':name:' \
          ':json:'
        ;;
      add-from-claude-desktop)
        _arguments \
          '(-s --scope)'{-s,--scope}'[Configuration scope]:scope:(local user project)' \
          '(-h --help)'{-h,--help}'[Display help]'
        ;;
      get)
        _arguments \
          '(-h --help)'{-h,--help}'[Display help]' \
          ':name:'
        ;;
      list|reset-project-choices|help)
        _arguments '(-h --help)'{-h,--help}'[Display help]'
        ;;
      *)
        _message 'no more arguments'
        ;;
    esac
    return
    ;;
  plugin|plugins)
    if (( CURRENT == 3 )); then
      _describe 'plugin command' plugin_commands
      return
    fi
    case $words[3] in
      marketplace)
        if (( CURRENT == 4 )); then
          _describe 'marketplace command' marketplace_commands
          return
        fi
        case $words[4] in
          add)
            _arguments \
              '--scope[Where to declare the marketplace]:scope:(user project local)' \
              '*--sparse[Limit checkout to specific directories]:path:_files' \
              '(-h --help)'{-h,--help}'[Display help]' \
              ':source:_files'
            ;;
          list)
            _arguments \
              '--json[Output as JSON]' \
              '(-h --help)'{-h,--help}'[Display help]'
            ;;
          remove|rm)
            _arguments \
              '(-h --help)'{-h,--help}'[Display help]' \
              ':name:'
            ;;
          update)
            _arguments \
              '(-h --help)'{-h,--help}'[Display help]' \
              ':name:'
            ;;
          help)
            _arguments '(-h --help)'{-h,--help}'[Display help]'
            ;;
          *)
            _message 'no more arguments'
            ;;
        esac
        ;;
      install|i)
        _arguments \
          '(-s --scope)'{-s,--scope}'[Installation scope]:scope:(user project local)' \
          '(-h --help)'{-h,--help}'[Display help]' \
          ':plugin:'
        ;;
      uninstall|remove)
        _arguments \
          '(-s --scope)'{-s,--scope}'[Uninstall from scope]:scope:(user project local)' \
          '(-h --help)'{-h,--help}'[Display help]' \
          ':plugin:'
        ;;
      enable)
        _arguments \
          '(-s --scope)'{-s,--scope}'[Installation scope]:scope:(user project local)' \
          '(-h --help)'{-h,--help}'[Display help]' \
          ':plugin:'
        ;;
      disable)
        _arguments \
          '(-s --scope)'{-s,--scope}'[Installation scope]:scope:(user project local)' \
          '(-h --help)'{-h,--help}'[Display help]' \
          ':plugin:'
        ;;
      list)
        _arguments \
          '--available[Include available plugins from marketplaces]' \
          '--json[Output as JSON]' \
          '(-h --help)'{-h,--help}'[Display help]'
        ;;
      prune|autoremove)
        _arguments \
          '--dry-run[List what would be removed without removing]' \
          '(-s --scope)'{-s,--scope}'[Prune at scope]:scope:(user project local)' \
          '(-y --yes)'{-y,--yes}'[Skip the confirmation prompt]' \
          '(-h --help)'{-h,--help}'[Display help]'
        ;;
      tag)
        _arguments \
          '--dry-run[Print what would be tagged without creating it]' \
          '(-f --force)'{-f,--force}'[Skip dirty-tree and existing-tag checks]' \
          '(-m --message)'{-m,--message}'[Tag annotation message]:message:' \
          '--push[Push the tag after creating it]' \
          '--remote[Remote to push to]:name:' \
          '(-h --help)'{-h,--help}'[Display help]' \
          ':path:_files -/'
        ;;
      update)
        _arguments \
          '(-s --scope)'{-s,--scope}'[Installation scope]:scope:(user project local managed)' \
          '(-h --help)'{-h,--help}'[Display help]' \
          ':plugin:'
        ;;
      validate)
        _arguments \
          '(-h --help)'{-h,--help}'[Display help]' \
          ':path:_files'
        ;;
      help)
        _arguments '(-h --help)'{-h,--help}'[Display help]'
        ;;
      *)
        _message 'no more arguments'
        ;;
    esac
    return
    ;;
  project)
    if (( CURRENT == 3 )); then
      _describe 'project command' project_commands
      return
    fi
    case $words[3] in
      purge)
        _arguments \
          '--all[Purge state for every project]' \
          '--dry-run[List what would be deleted without deleting]' \
          '(-i --interactive)'{-i,--interactive}'[Prompt for each item before deleting]' \
          '(-y --yes)'{-y,--yes}'[Skip confirmation prompt]' \
          '(-h --help)'{-h,--help}'[Display help]' \
          ':path:_files -/'
        ;;
      help)
        _arguments '(-h --help)'{-h,--help}'[Display help]'
        ;;
      *)
        _message 'no more arguments'
        ;;
    esac
    return
    ;;
  agents)
    _arguments \
      '--setting-sources[Comma-separated list of setting sources to load]:sources:(user project local)' \
      '(-h --help)'{-h,--help}'[Display help]'
    return
    ;;
  install)
    _arguments \
      '--force[Force installation even if already installed]' \
      '(-h --help)'{-h,--help}'[Display help]' \
      ':target:(stable latest)'
    return
    ;;
  ultrareview)
    _arguments \
      '--json[Print raw bugs.json payload]' \
      '--timeout[Maximum minutes to wait for review]:minutes:' \
      '(-h --help)'{-h,--help}'[Display help]' \
      ':target:'
    return
    ;;
  remote-control)
    _arguments \
      '--name[Remote Control session name]:name:' \
      '--remote-control-session-name-prefix[Session name prefix]:prefix:' \
      '(-h --help)'{-h,--help}'[Display help]'
    return
    ;;
  setup-token|doctor|update|upgrade)
    _arguments '(-h --help)'{-h,--help}'[Display help]'
    return
    ;;
esac

_arguments -s \
  '*--add-dir[Additional directories to allow tool access to]:directory:_files -/' \
  '--agent[Agent for the current session]:agent:' \
  '--agents[JSON object defining custom agents]:json:' \
  '--allow-dangerously-skip-permissions[Add bypassPermissions to the mode cycle]' \
  '*--allowedTools[Comma or space-separated list of tool names to allow]:tools:' \
  '*--allowed-tools[Comma or space-separated list of tool names to allow]:tools:' \
  '--append-system-prompt[Append a system prompt to the default system prompt]:prompt:' \
  '--append-system-prompt-file[Append system prompt text from a file]:file:_files' \
  '--bare[Minimal mode for faster scripted calls]' \
  '*--betas[Beta headers to include in API requests]:beta:' \
  '--brief[Enable SendUserMessage tool for agent-to-user communication]' \
  '*--channels[Channel notifications to listen for]:channel:' \
  '--chrome[Enable Claude in Chrome integration]' \
  '(-c --continue)'{-c,--continue}'[Continue the most recent conversation]' \
  '*--dangerously-load-development-channels[Enable non-allowlisted development channels]:channel:' \
  '--dangerously-skip-permissions[Bypass all permission checks]' \
  '(-d --debug)'{-d,--debug}'[Enable debug mode with optional category filtering]::filter:' \
  '--debug-file[Write debug logs to a file]:path:_files' \
  '--disable-slash-commands[Disable all skills]' \
  '*--disallowedTools[Comma or space-separated list of tool names to deny]:tools:' \
  '*--disallowed-tools[Comma or space-separated list of tool names to deny]:tools:' \
  '--effort[Effort level for the current session]:level:(low medium high xhigh max)' \
  '--exclude-dynamic-system-prompt-sections[Move per-machine sections into the first user message]' \
  '--fallback-model[Enable automatic fallback to specified model]:model:' \
  '*--file[File resource to download at startup]:spec:' \
  '--fork-session[Create a new session ID when resuming]' \
  '--from-pr[Resume a session linked to a pull request]::value:' \
  '(-h --help)'{-h,--help}'[Display help for command]' \
  '--ide[Automatically connect to IDE on startup]' \
  '--include-hook-events[Include hook lifecycle events in stream-json output]' \
  '--include-partial-messages[Include partial message chunks as they arrive]' \
  '--init[Run setup hooks before a print-mode session]' \
  '--init-only[Run setup hooks and exit without starting a conversation]' \
  '--input-format[Input format]:format:(text stream-json)' \
  '--json-schema[JSON Schema for structured output validation]:schema:' \
  '--maintenance[Run maintenance hooks before a print-mode session]' \
  '--max-budget-usd[Maximum dollar amount to spend on API calls]:amount:' \
  '--max-turns[Limit the number of agentic turns]:turns:' \
  '*--mcp-config[Load MCP servers from JSON files or strings]:config:_files' \
  '--mcp-debug[Deprecated, use --debug instead]' \
  '--model[Model for the current session]:model:' \
  '(-n --name)'{-n,--name}'[Display name for this session]:name:' \
  '--no-chrome[Disable Claude in Chrome integration]' \
  '--no-session-persistence[Disable session persistence]' \
  '--output-format[Output format]:format:(text json stream-json)' \
  '--permission-mode[Permission mode to use for the session]:mode:(acceptEdits auto bypassPermissions default dontAsk plan)' \
  '--permission-prompt-tool[MCP tool to handle permission prompts]:tool:' \
  '*--plugin-dir[Load plugins from directories for this session]:directory:_files -/' \
  '(-p --print)'{-p,--print}'[Print response and exit]' \
  '--remote[Create a web session on claude.ai]:task:' \
  '--remote-control[Start an interactive session with Remote Control]::name:' \
  '--rc[Start an interactive session with Remote Control]::name:' \
  '--remote-control-session-name-prefix[Remote Control session name prefix]:prefix:' \
  '--replay-user-messages[Re-emit user messages from stdin]' \
  '(-r --resume)'{-r,--resume}'[Resume a conversation by session ID or name]::value:' \
  '--session-id[Use a specific session ID]:uuid:' \
  '--setting-sources[Comma-separated list of setting sources to load]:sources:(user project local)' \
  '--settings[Path to settings JSON or JSON string]:file:_files' \
  '--strict-mcp-config[Only use MCP servers from --mcp-config]' \
  '--system-prompt[System prompt to use for the session]:prompt:' \
  '--system-prompt-file[Load replacement system prompt from a file]:file:_files' \
  '--teleport[Resume a web session in the local terminal]' \
  '--teammate-mode[How agent team teammates display]:mode:(auto tmux in-process)' \
  '--tmux[Create a tmux session for the worktree]' \
  '*--tools[Specify the list of available tools]:tools:' \
  '--verbose[Override verbose mode setting from config]' \
  '(-v --version)'{-v,--version}'[Output the version number]' \
  '(-w --worktree)'{-w,--worktree}'[Create a new git worktree for this session]::name:' \
  '1:command:(agents auth auto-mode doctor install mcp plugin plugins project remote-control setup-token ultrareview update upgrade)' \
  '*:prompt:->prompt'

case $state in
  prompt)
    _message 'prompt text'
    ;;
esac
